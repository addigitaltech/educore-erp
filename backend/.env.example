APP_NAME="EduCore ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=educore_db
DB_USERNAME=root
DB_PASSWORD=

# ── SESSION / CACHE ───────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# ── MAIL (optional) ───────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@educore.io"
MAIL_FROM_NAME="${APP_NAME}"

# ── FRONTEND URL (for CORS) ───────────────
FRONTEND_URL=http://localhost:5173
